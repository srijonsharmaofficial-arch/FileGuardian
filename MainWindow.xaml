<Window x:Class="FileGuardian.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FileGuardian" Height="450" Width="700"
        Icon="/Assets/AppIcon.ico"
        Background="{StaticResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="40,0,40,30">
            <TextBlock Text="The Ultimate App to Scan or Organize Files"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryGreenBrush}"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center"/>
            <TextBlock Text="Built with care, free to use. Let us know if anything should change."
                       FontSize="13"
                       Foreground="{StaticResource TextBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0"
                       TextWrapping="Wrap"
                       TextAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Vertical" HorizontalAlignment="Center">

            <Button x:Name="ForensicsButton"
                    Content="Scan Your Files"
                    Width="300" Height="60"
                    Style="{StaticResource ClassicButtonStyle}"
                    Margin="0,10"
                    Click="ForensicsButton_Click"/>

            <Button x:Name="OrganizerButton"
                    Content="Organize Your Files"
                    Width="300" Height="60"
                    Style="{StaticResource ClassicButtonStyle}"
                    Margin="0,10"
                    Click="OrganizerButton_Click"/>

        </StackPanel>
    </Grid>
</Window>