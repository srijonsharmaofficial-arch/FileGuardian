<Window x:Class="FileGuardian.ForensicsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Digital Forensics" Height="700" Width="750"
        Icon="/Assets/AppIcon.ico"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Border Width="6" Height="40" Background="{StaticResource PrimaryGreenBrush}" CornerRadius="3" Margin="0,0,15,0"/>
                <StackPanel>
                    <TextBlock Text="Digital Forensics"
                               FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryGreenBrush}"/>
                    <TextBlock Text="Inspect file metadata and generate evidence reports"
                               FontSize="13"
                               Foreground="{StaticResource TextBrush}"/>
                </StackPanel>
            </StackPanel>

            <Button Grid.Column="1"
                    x:Name="BackButton"
                    Content="← Back"
                    Width="100" Height="40"
                    Style="{StaticResource ClassicButtonStyle}"
                    VerticalAlignment="Top"
                    Click="BackButton_Click"/>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      Style="{StaticResource ThemedScrollViewerStyle}"
                      VerticalScrollBarVisibility="Auto">
            <Border Style="{StaticResource CardBorderStyle}" VerticalAlignment="Top">
                <StackPanel>

                    <TextBlock Text="Select a file or folder to investigate" Style="{StaticResource SectionLabelStyle}"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SelectedPathTextBox"
                             Grid.Column="0"
                             Style="{StaticResource ModernTextBoxStyle}"
                             IsReadOnly="True"
                             Text="Nothing selected"
                             Margin="0,0,10,0"/>
                        <Button x:Name="BrowseFileButton"
                            Grid.Column="1"
                            Content="Browse File..."
                            Width="130" Height="40"
                            Style="{StaticResource ClassicButtonStyle}"
                            Margin="0,0,10,0"
                            Click="BrowseFileButton_Click"/>
                        <Button x:Name="BrowseFolderButton"
                            Grid.Column="2"
                            Content="Browse Folder..."
                            Width="130" Height="40"
                            Style="{StaticResource ClassicButtonStyle}"
                            Click="BrowseFolderButton_Click"/>
                    </Grid>

                    <Separator Margin="0,0,0,20" Background="{StaticResource BorderGrayBrush}"/>

                    <TextBlock Text="Details" Style="{StaticResource SectionLabelStyle}"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="File Name:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="NameValueText" Text="-"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Path:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="PathValueText" Text="-" TextTrimming="CharacterEllipsis"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Type:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="ExtValueText" Text="-"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Size:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="SizeValueText" Text="-"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Created On:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="CreatedValueText" Text="-"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Modified On:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="ModifiedValueText" Text="-"/>
                    </Grid>

                    <Separator Margin="0,0,0,20" Background="{StaticResource BorderGrayBrush}"/>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Suspicious Findings" Style="{StaticResource SectionLabelStyle}"/>
                            <Border BorderBrush="{StaticResource BorderGrayBrush}" BorderThickness="1.5" CornerRadius="5" Height="140">
                                <ListBox x:Name="SuspiciousFindingsListBox" BorderThickness="0" Background="Transparent"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Possible Solutions" Style="{StaticResource SectionLabelStyle}"/>
                            <Border BorderBrush="{StaticResource BorderGrayBrush}" BorderThickness="1.5" CornerRadius="5" Height="140">
                                <ScrollViewer Style="{StaticResource ThemedScrollViewerStyle}"
                                          VerticalScrollBarVisibility="Auto"
                                          Padding="10">
                                    <TextBlock x:Name="PossibleSolutionsText"
                                           Text="Solutions will appear here after a scan."
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource TextBrush}"/>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Separator Margin="0,0,0,20" Background="{StaticResource BorderGrayBrush}"/>

                    <TextBlock Text="Virus Scan (Windows Defender)" Style="{StaticResource SectionLabelStyle}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="ScanVirusButton"
                            Content="Scan for Viruses"
                            Width="170" Height="40"
                            Style="{StaticResource ClassicButtonStyle}"
                            IsEnabled="False"
                            Click="ScanVirusButton_Click"/>
                    </StackPanel>
                    <TextBlock x:Name="VirusScanStatusText"
                           Text="No scan run yet."
                           FontSize="14"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource TextBrush}"/>

                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>